# Required — SQLite DB file (path is relative to the prisma/ folder)
DATABASE_URL="file:./dev.db"

# Required — admin dashboard login password
ADMIN_PASSWORD="change-me-strong-password"

# Required — JWT signing secret for admin session cookies (min ~32 random characters in production)
ADMIN_JWT_SECRET="change-me-min-32-chars-random-secret-for-jwt"

# Optional — Google AI Studio API key for Edo Assistant (multilingual shop assistant)
GEMINI_API_KEY=""

# Optional — Gemini model id (default used in code: gemini-2.0-flash)
GEMINI_MODEL="gemini-2.0-flash"

# Optional — AI chat rate limits (IP-hashed, stored in DB; defaults: 12/min, 80/hour)
# CHAT_RATE_LIMIT_PER_MINUTE="12"
# CHAT_RATE_LIMIT_PER_HOUR="80"
# CHAT_RATE_IP_SALT="optional-extra-salt-for-ip-hashing"

# Optional — canonical site URL for metadata and Open Graph (default: http://localhost:3000)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
